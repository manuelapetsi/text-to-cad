{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "*": false,
      "main": true
    }
  },
  "installCommand": "npm --prefix viewer ci",
  "buildCommand": "npm --prefix viewer run build",
  "outputDirectory": "viewer/dist",
  "rewrites": [
    {
      "source": "/__cad/server",
      "destination": "/api/cad/server"
    },
    {
      "source": "/__cad/catalog",
      "destination": "/api/cad/catalog"
    },
    {
      "source": "/__cad/download",
      "destination": "/api/cad/download"
    },
    {
      "source": "/__cad/reveal",
      "destination": "/api/cad/reveal"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
